---
import PageLayout from "../layouts/PageLayout.astro";
import { t, getLangFromUrl } from "../i18n";
import { SITE } from "../content/site";

const lang = getLangFromUrl(Astro.url);
---

<PageLayout title={`${t(lang, "overOns.heading")} | EPC Expert`} description={t(lang, "overOns.intro")} lang={lang}>
  <section class="section-padding">
    <div class="container mx-auto max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-foreground text-center mb-8">{t(lang, "overOns.heading")}</h1>
      <div class="prose prose-lg max-w-none prose-headings:text-foreground prose-p:text-muted-foreground prose-a:text-primary prose-strong:text-foreground" set:html={t(lang, "overOns.content")} />

      <div class="mt-12 bg-muted p-8 rounded-xl">
        <h2 class="text-xl font-bold text-foreground mb-4">{t(lang, "overOns.credentialsTitle")}</h2>
        <ul class="space-y-3 text-muted-foreground">
          <li>VEKA Erkenning: {SITE.recognition.join(" & ")}</li>
          <li>Ondernemingsnummer: {SITE.vat}</li>
          <li>Talen: Nederlands, Frans, Engels</li>
        </ul>
      </div>

      <div class="mt-8 text-center">
        <a href="/offerte" class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-primary-foreground font-bold text-lg rounded-xl hover:opacity-90 transition-all shadow-lg">
          {t(lang, "cta.button")}
        </a>
      </div>
    </div>
  </section>
</PageLayout>
