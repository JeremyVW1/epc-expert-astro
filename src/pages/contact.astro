---
import PageLayout from "../layouts/PageLayout.astro";
import { t, getLangFromUrl } from "../i18n";
import { SITE } from "../content/site";

const lang = getLangFromUrl(Astro.url);
---

<PageLayout title={t(lang, "meta.contactTitle")} description={t(lang, "meta.contactDesc")} lang={lang}>
  <section class="section-padding">
    <div class="container mx-auto max-w-5xl">
      <h1 class="text-4xl md:text-5xl font-bold text-foreground text-center mb-4">{t(lang, "contact.title")}</h1>
      <p class="text-muted-foreground text-center mb-12">{t(lang, "contact.subtitle")}</p>
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-xl font-bold text-foreground mb-4">{t(lang, "contact.aboutTitle")}</h2>
          <p class="text-muted-foreground mb-8">{t(lang, "contact.aboutText")}</p>
          <div class="space-y-4">
            <a href={SITE.phoneHref} class="flex items-center gap-3 text-foreground hover:text-primary transition-colors">
              <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" /></svg>
              {SITE.phone}
            </a>
            <a href={SITE.emailHref} class="flex items-center gap-3 text-foreground hover:text-primary transition-colors">
              <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7" /></svg>
              {SITE.email}
            </a>
            <div class="flex items-center gap-3 text-foreground">
              <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
              Tervuren, Vlaams-Brabant
            </div>
          </div>
          <div class="mt-8 p-4 bg-primary-light rounded-xl">
            <p class="text-sm font-medium text-foreground">{t(lang, "contact.recognition")}: {SITE.recognition.join(" & ")}</p>
          </div>
          <div class="mt-8 rounded-xl overflow-hidden border border-border">
            <iframe title="EPC Expert Tervuren" src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d40326.45!2d4.48!3d50.82!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c3dce7d1b58e7d%3A0x53e0c11a2c4c0c6d!2sTervuren!5e0!3m2!1snl!2sbe!4v1" width="100%" height="250" style="border:0" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>
        <div class="bg-muted p-8 rounded-xl">
          <h2 class="text-xl font-bold text-foreground mb-6">{t(lang, "contact.formTitle")}</h2>
          <p class="text-muted-foreground mb-4">
            {t(lang, "contact.formIntro")} <a href="/offerte" class="text-primary font-semibold hover:underline">{t(lang, "nav.offerte")}</a>.
          </p>
          <div class="space-y-4 mt-6">
            <a href={SITE.phoneHref} class="flex items-center justify-center gap-2 w-full py-3 bg-primary text-primary-foreground font-semibold rounded-lg hover:opacity-90 transition">
              {SITE.phone}
            </a>
            <a href={SITE.emailHref} class="flex items-center justify-center gap-2 w-full py-3 border-2 border-primary text-primary font-semibold rounded-lg hover:bg-primary/5 transition">
              {SITE.email}
            </a>
          </div>
        </div>
      </div>

      <div class="mt-12 grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <a href="/offerte" class="group flex flex-col gap-2 p-6 rounded-xl border border-border bg-card hover:border-primary hover:shadow-lg transition-all">
          <span class="text-sm font-semibold text-primary">{t(lang, "nav.offerte")}</span>
          <span class="text-muted-foreground text-sm">Vraag direct een offerte aan via ons formulier</span>
        </a>
        <a href="/faq" class="group flex flex-col gap-2 p-6 rounded-xl border border-border bg-card hover:border-primary hover:shadow-lg transition-all">
          <span class="text-sm font-semibold text-primary">FAQ</span>
          <span class="text-muted-foreground text-sm">Antwoorden op veelgestelde vragen</span>
        </a>
      </div>
    </div>
  </section>
</PageLayout>
