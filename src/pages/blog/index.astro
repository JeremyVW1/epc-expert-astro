---
import PageLayout from "../../layouts/PageLayout.astro";
import { t, getLangFromUrl } from "../../i18n";
import { SITE } from "../../content/site";
import { BLOG_POSTS } from "../../content/blog";
import { breadcrumbSchema } from "../../utils/schema";

const lang = getLangFromUrl(Astro.url);
const schemas = [breadcrumbSchema([
  { name: "Home", url: SITE.website },
  { name: "Blog", url: `${SITE.website}/blog` },
])];

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("nl-BE", { day: "numeric", month: "long", year: "numeric" });
}
---

<PageLayout title={t(lang, "meta.blogTitle")} description={t(lang, "meta.blogDesc")} lang={lang} schema={schemas}>
  <section class="section-padding">
    <div class="container mx-auto max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-bold text-foreground text-center mb-4">{t(lang, "blog.title")}</h1>
      <p class="text-lg text-muted-foreground text-center mb-12 max-w-2xl mx-auto">
        Praktische tips, wetgeving en advies over EPC-certificaten in Vlaanderen.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        {BLOG_POSTS.map((post) => (
          <a href={`/blog/${post.slug}`} class="bg-muted/50 rounded-xl p-6 hover:shadow-lg transition-all hover:-translate-y-1 group flex flex-col">
            <span class="inline-block self-start px-2.5 py-1 bg-primary-light text-primary text-xs rounded-full font-medium mb-3">
              {post.category}
            </span>
            <h2 class="font-bold text-foreground text-lg mb-3 group-hover:text-primary transition-colors leading-snug">
              {post.title}
            </h2>
            <p class="text-muted-foreground text-sm mb-4 line-clamp-3 flex-1">{post.excerpt}</p>
            <div class="flex items-center justify-between text-xs text-muted-foreground mt-auto pt-4 border-t border-border">
              <span>{formatDate(post.date)}</span>
              <span>{post.readingTime} min</span>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center">
        <a href="/offerte" class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-white font-bold text-lg rounded-xl hover:bg-primary/90 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          Vraag uw EPC aan
        </a>
      </div>
    </div>
  </section>
</PageLayout>
