---
import PageLayout from "../../layouts/PageLayout.astro";
import { t, getLangFromUrl } from "../../i18n";
import { SITE } from "../../content/site";
import { BLOG_POSTS } from "../../content/blog";
import { blogPostSchema, breadcrumbSchema } from "../../utils/schema";

export function getStaticPaths() {
  return BLOG_POSTS.map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const lang = getLangFromUrl(Astro.url);

const schemas = [
  blogPostSchema(post),
  breadcrumbSchema([
    { name: "Home", url: SITE.website },
    { name: "Blog", url: `${SITE.website}/blog` },
    { name: post.title, url: `${SITE.website}/blog/${post.slug}` },
  ]),
];

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("nl-BE", { day: "numeric", month: "long", year: "numeric" });
}
---

<PageLayout title={`${post.title} | EPC Expert Blog`} description={post.excerpt} canonical={`${SITE.website}/blog/${post.slug}`} lang={lang} schema={schemas}>
  <article class="section-padding">
    <div class="container mx-auto max-w-3xl">
      <a href="/blog" class="inline-flex items-center gap-2 text-primary font-semibold hover:underline mb-8">
        ← Terug naar blog
      </a>

      <header class="mb-10">
        <span class="inline-block px-3 py-1 bg-primary-light text-primary text-sm rounded-full font-medium mb-4">
          {post.category}
        </span>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-6 leading-tight">
          {post.title}
        </h1>
        <div class="flex flex-wrap items-center gap-4 text-muted-foreground text-sm">
          <span>{formatDate(post.date)}</span>
          <span>{post.readingTime} min leestijd</span>
        </div>
      </header>

      <div class="prose prose-lg max-w-none prose-headings:text-foreground prose-headings:font-bold prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-p:text-muted-foreground prose-p:leading-relaxed prose-li:text-muted-foreground prose-a:text-primary prose-a:font-semibold prose-strong:text-foreground [&_.cta-block]:bg-primary-light [&_.cta-block]:rounded-xl [&_.cta-block]:p-6 [&_.cta-block]:mt-10 [&_.cta-block]:text-center [&_.cta-block_a]:text-primary [&_.cta-block_a]:font-bold" set:html={post.content} />
    </div>
  </article>
</PageLayout>
