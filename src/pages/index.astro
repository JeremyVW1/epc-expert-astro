---
import PageLayout from "../layouts/PageLayout.astro";
import { SITE } from "../content/site";
import { REGIONS } from "../content/regions";
import { t, getLangFromUrl } from "../i18n";
import { localBusinessSchema, serviceSchema, breadcrumbSchema } from "../utils/schema";
import heroImage from "../assets/hero-houses-v5.jpg";

const lang = getLangFromUrl(Astro.url);

const schemas = [
  localBusinessSchema(),
  serviceSchema(),
  breadcrumbSchema([{ name: "Home", url: `${SITE.website}/` }]),
];

const showRegions = REGIONS.filter((r) => r.showOnSite);
---

<PageLayout
  title={t(lang, "meta.homeTitle")}
  description={t(lang, "meta.homeDesc")}
  canonical={SITE.website}
  lang={lang}
  schema={schemas}
>
  <!-- Hero -->
  <section aria-label="Hero" class="relative overflow-hidden min-h-[600px] md:min-h-[700px] flex items-center">
    <div class="absolute inset-0">
      <img src={heroImage.src} alt="Belgische woningen in Vlaams-Brabant" class="w-full h-full object-cover" width="1920" height="1080" />
      <div class="absolute inset-0 bg-black/20"></div>
    </div>
    <div class="container mx-auto relative z-10 px-4 py-12 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 backdrop-blur-sm rounded-full text-white/90 text-sm font-medium mb-6 border border-white/20">
            VEKA Erkend — EP18784 & EP18782
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight font-display">
            {t(lang, "hero.title")}
          </h1>
          <p class="mt-6 text-lg text-white/80 max-w-xl">{t(lang, "hero.subtitle")}</p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/offerte" class="inline-flex items-center gap-2 px-8 py-4 bg-accent text-accent-foreground font-bold text-lg rounded-xl hover:bg-accent-dark transition-all shadow-lg shadow-accent/30 hover:shadow-xl hover:shadow-accent/40 hover:-translate-y-0.5">
              {t(lang, "hero.cta")}
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7" /></svg>
            </a>
            <a href="/prijzen" class="inline-flex items-center px-8 py-4 border-2 border-white/40 text-white font-bold text-lg rounded-xl hover:bg-white/10 transition-all backdrop-blur-sm">
              {t(lang, "hero.ctaSecondary")}
            </a>
          </div>
        </div>
        <!-- EPC scale -->
        <div class="hidden lg:flex flex-col gap-2.5 pl-8">
          {[
            { label: "A+", w: 40, color: "bg-[hsl(var(--epc-a-plus))]" },
            { label: "A", w: 50, color: "bg-[hsl(var(--epc-a))]" },
            { label: "B", w: 60, color: "bg-[hsl(var(--epc-b))]" },
            { label: "C", w: 70, color: "bg-[hsl(var(--epc-c))]" },
            { label: "D", w: 80, color: "bg-[hsl(var(--epc-d))]" },
            { label: "E", w: 90, color: "bg-[hsl(var(--epc-e))]" },
            { label: "F", w: 100, color: "bg-[hsl(var(--epc-f))]" },
          ].map(({ label, w, color }) => (
            <div class={`${color} text-white font-bold rounded-r-xl flex items-center justify-center h-12 shadow-md`} style={`width:${w}%`}>
              {label}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Urgency banner -->
  <section class="bg-gradient-to-r from-accent/10 via-accent/5 to-accent/10 py-5 border-y border-accent/20">
    <div class="container mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 px-4">
      <p class="text-foreground font-medium text-center sm:text-left">{t(lang, "urgency.text")}</p>
      <a href="/offerte" class="flex-shrink-0 px-6 py-2.5 bg-accent text-accent-foreground font-semibold rounded-lg hover:bg-accent-dark transition-colors shadow-md">
        {t(lang, "urgency.cta")}
      </a>
    </div>
  </section>

  <!-- Regions -->
  <section aria-label="Servicegebied" class="section-padding bg-background">
    <div class="container mx-auto">
      <p class="text-center text-primary font-semibold text-sm uppercase tracking-wider mb-3">Regio</p>
      <h2 class="text-3xl md:text-4xl font-bold text-foreground text-center mb-4 font-display">{t(lang, "regions.title")}</h2>
      <p class="text-muted-foreground text-center mb-10 max-w-2xl mx-auto">{t(lang, "regions.subtitle")}</p>
      <div class="flex flex-wrap justify-center gap-3 max-w-4xl mx-auto">
        {showRegions.map((r) => (
          <a href={`/regio/${r.slug}`} class="px-4 py-2 rounded-full border border-primary/20 text-sm font-medium text-foreground bg-primary/5 hover:bg-primary hover:text-primary-foreground hover:border-primary transition-all duration-200 hover:shadow-md">
            {r.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-br from-primary via-primary to-[hsl(var(--primary-dark))] section-padding">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4 font-display">{t(lang, "cta.title")}</h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">{t(lang, "cta.subtitle")}</p>
      <a href="/offerte" class="inline-flex items-center gap-2 px-8 py-4 bg-accent text-accent-foreground font-bold text-lg rounded-xl hover:bg-accent-dark transition-all shadow-lg shadow-accent/30 hover:shadow-xl hover:-translate-y-0.5">
        {t(lang, "cta.button")}
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7" /></svg>
      </a>
      <p class="mt-6 text-white/70">
        <a href={SITE.phoneHref} class="hover:text-white transition-colors font-semibold text-lg">{SITE.phone}</a>
      </p>
    </div>
  </section>
</PageLayout>
