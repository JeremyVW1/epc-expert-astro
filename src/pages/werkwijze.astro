---
import PageLayout from "../layouts/PageLayout.astro";
import { t, getLangFromUrl } from "../i18n";
import { SITE } from "../content/site";
import { breadcrumbSchema } from "../utils/schema";

const lang = getLangFromUrl(Astro.url);
const schemas = [breadcrumbSchema([
  { name: "Home", url: SITE.website },
  { name: t(lang, "nav.werkwijze"), url: `${SITE.website}/werkwijze` },
])];

const steps = [
  { num: 1, titleKey: "werkwijze.step1title", descKey: "werkwijze.step1desc", detailKey: "werkwijze.step1detail" },
  { num: 2, titleKey: "werkwijze.step2title", descKey: "werkwijze.step2desc", detailKey: "werkwijze.step2detail" },
  { num: 3, titleKey: "werkwijze.step3title", descKey: "werkwijze.step3desc", detailKey: "werkwijze.step3detail" },
  { num: 4, titleKey: "werkwijze.step4title", descKey: "werkwijze.step4desc", detailKey: "werkwijze.step4detail" },
];
---

<PageLayout title={t(lang, "meta.werkwijzeTitle")} description={t(lang, "meta.werkwijzeDesc")} lang={lang} schema={schemas}>
  <section class="section-padding">
    <div class="container mx-auto max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-bold text-foreground text-center mb-6">{t(lang, "werkwijze.title")}</h1>
      <p class="text-lg text-muted-foreground text-center mb-16 max-w-2xl mx-auto">{t(lang, "werkwijze.pageIntro")}</p>

      <div class="space-y-8">
        {steps.map(({ num, titleKey, descKey, detailKey }) => (
          <div class="rounded-2xl border border-border/50 bg-card shadow-sm overflow-hidden">
            <div class="flex items-start gap-4 p-6">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary text-primary-foreground font-bold flex items-center justify-center text-sm">{num}</div>
              <div>
                <h2 class="text-xl font-bold text-foreground">{t(lang, titleKey)}</h2>
                <p class="text-muted-foreground mt-2" set:html={t(lang, descKey)} />
              </div>
            </div>
            <div class="px-6 pb-6 pt-2">
              <div class="text-muted-foreground leading-relaxed prose prose-sm max-w-none [&_ul]:mt-3 [&_ul]:space-y-1 [&_li]:text-muted-foreground [&_a]:text-primary [&_a]:font-semibold [&_strong]:text-foreground" set:html={t(lang, detailKey)} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-br from-primary via-primary to-[hsl(var(--primary-dark))] section-padding">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4 font-display">{t(lang, "cta.title")}</h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">{t(lang, "cta.subtitle")}</p>
      <a href="/offerte" class="inline-flex items-center gap-2 px-8 py-4 bg-accent text-accent-foreground font-bold text-lg rounded-xl hover:bg-accent-dark transition-all shadow-lg">
        {t(lang, "cta.button")}
      </a>
    </div>
  </section>
</PageLayout>
