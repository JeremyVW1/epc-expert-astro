---
import { SITE } from "../content/site";
import { t } from "../i18n";
import type { Language } from "../i18n";

interface Props { lang?: Language }
const { lang = "nl" } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-gradient-to-br from-[hsl(215,90%,12%)] to-[hsl(215,80%,18%)] text-white">
  <div class="container mx-auto px-4 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <div class="lg:col-span-1">
        <img src={SITE.logo} alt="EPC Expert" class="h-12 w-auto mb-4 brightness-0 invert" width="160" height="48" />
        <p class="text-white/70 text-sm mt-2">{t(lang, "tagline")}</p>
      </div>
      <div>
        <h3 class="font-semibold text-lg mb-4">{t(lang, "footer.navigation")}</h3>
        <ul class="space-y-2 text-sm text-white/70">
          {[
            { to: "/", label: t(lang, "nav.home") },
            { to: "/werkwijze", label: t(lang, "nav.werkwijze") },
            { to: "/prijzen", label: t(lang, "nav.prijzen") },
            { to: "/over-ons", label: t(lang, "overOns.heading") },
            { to: "/faq", label: t(lang, "nav.faq") },
            { to: "/blog", label: t(lang, "nav.blog") },
          ].map((l) => (
            <li><a href={l.to} class="hover:text-white transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="font-semibold text-lg mb-4">{t(lang, "footer.diensten")}</h3>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/diensten/residentieel" class="hover:text-white transition-colors">{t(lang, "services.residential.title")}</a></li>
          <li><a href="/diensten/niet-residentieel" class="hover:text-white transition-colors">{t(lang, "services.nonResidential.title")}</a></li>
          <li><a href="/diensten/gemeenschappelijke-delen" class="hover:text-white transition-colors">{t(lang, "services.commonParts.title")}</a></li>
          <li><a href="/asbestattest" class="hover:text-white transition-colors">{t(lang, "asbestPage.footerLink")}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold text-lg mb-4">{t(lang, "footer.contact")}</h3>
        <ul class="space-y-3 text-sm text-white/70">
          <li class="flex items-center gap-2">
            <svg class="h-4 w-4 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
            Tervuren, Vlaams-Brabant
          </li>
          <li>
            <a href={SITE.phoneHref} class="flex items-center gap-2 hover:text-white transition-colors">
              <svg class="h-4 w-4 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" /></svg>
              {SITE.phone}
            </a>
          </li>
          <li>
            <a href={SITE.emailHref} class="flex items-center gap-2 hover:text-white transition-colors">
              <svg class="h-4 w-4 flex-shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7" /></svg>
              {SITE.email}
            </a>
          </li>
        </ul>
        <div class="mt-4 text-xs text-white/50">
          <p>{t(lang, "footer.recognition")}: {SITE.recognition.join(" & ")}</p>
        </div>
      </div>
    </div>
    <div class="mt-12 pt-6 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-white/50">
      <p>{SITE.company} — {SITE.vat} | &copy; {year} {SITE.name}. {t(lang, "footer.rights")}.</p>
      <div class="flex gap-4">
        <a href="/privacy" class="hover:text-white transition-colors">{t(lang, "privacy.heading")}</a>
        <a href="/sitemap" class="hover:text-white transition-colors">{t(lang, "common.sitemap")}</a>
      </div>
    </div>
  </div>
</footer>
